<Page x:Class="WPFChitaiGorod.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WPFChitaiGorod.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage"
      Background="White">

    <Grid>
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Center">
                <Image Source="/Resources/icon.ico" Height="120">

                </Image>
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Comic Sans MS" FontSize="30" FontWeight="Bold">
                    ООО «ЧитайГород»
                </TextBlock>
            </StackPanel>
            <Border VerticalAlignment="Center" HorizontalAlignment="Center" Height="250" Width="550" CornerRadius="20" Background="#ABCFCE">
                <StackPanel>
                    <TextBlock HorizontalAlignment="Center" FontFamily="Comic Sans MS" FontSize="20">
                        Авторизация
                    </TextBlock>
                    
                    <TextBlock HorizontalAlignment="Center" Margin="0 10" FontSize="16" FontFamily="Comic Sans MS">
                        Логин
                    </TextBlock>
                    <TextBox Width="250" x:Name="LoginTxt" FontFamily="Comic Sans MS">
                        
                    </TextBox>
                    
                    <TextBlock HorizontalAlignment="Center" Margin="0 10" FontSize="16" FontFamily="Comic Sans MS">
                        Пароль
                    </TextBlock>
                    <PasswordBox Width="250" x:Name="PasswordTxt" FontFamily="Comic Sans MS">
                        
                    </PasswordBox>

                    <Button Margin="0 20 0 10"  FontFamily="Comic Sans MS" FontSize="16" HorizontalAlignment="Center" Background="#546F94" Click="LoginClientButton">
                        Войти
                    </Button>

                    <Button Margin="0 5 0 10"  FontFamily="Comic Sans MS" FontSize="16" HorizontalAlignment="Center" Background="#546F94" Click="LoginGostButton">
                        Войти как гость
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
