<Page x:Class="WPFChitaiGorod.Pages.AdminPage.ZakazMainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WPFChitaiGorod.Pages.AdminPage"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ZakazMainPage"
      Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="7*"/>
            <RowDefinition Height="31*"/>
            <RowDefinition Height="7*"/>
        </Grid.RowDefinitions>

        <Border Background="#ABCFCE" Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <Image Source="/Resources/icon.ico" HorizontalAlignment="Left"/>
                <TextBlock VerticalAlignment="Center" FontFamily="Comic Sans MS" FontSize="30" FontWeight="Bold" Margin="150 0 0 0" HorizontalAlignment="Center">
                ООО «ЧитайГород»
                </TextBlock>
            </StackPanel>
        </Border>

        <ListView x:Name="TovarTableItems" Grid.Row="1" Margin="10,10,10,10" MaxWidth="1900">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="3" Padding="10" Margin="5" HorizontalAlignment="Stretch">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5*"/>
                                <ColumnDefinition Width="3*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" BorderBrush="Black" BorderThickness="1" Margin="5" Padding="10">
                                <StackPanel Margin="10 0 0 0" MaxWidth="1000">
                                    <TextBlock TextWrapping="Wrap" FontFamily="Comic Sans MS" FontSize="16" FontWeight="Bold">
                                    <Run Text="Артикул заказа: "/>
                                    <Run Text="{Binding ArticulTovar}"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" FontFamily="Comic Sans MS" FontSize="16">
                                    <Run Text="Статус заказа: "/>
                                    <Run Text="{Binding Zakaz_.StatusZakaz_.NameStatus}"/>
                                    </TextBlock>
                                    <TextBlock FontFamily="Comic Sans MS" FontSize="16">
                                    <Run Text="Адрес пункта выдачи: "/>
                                    <Run Text="{Binding Zakaz_.PunltVidachi_, StringFormat=' {0}.IndexPunkta, {0}.Gorod, {0}.Ulica, {0}.Dom'}"/>/>
                                    </TextBlock>
                                    <TextBlock FontFamily="Comic Sans MS" FontSize="16">
                                    <Run Text="Дата заказа: "/>
                                    <Run Text="{Binding Zakaz_.DataZakaz}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" BorderBrush="Black" BorderThickness="2">
                                <Grid Width="150" Height="150">
                                    <TextBlock TextWrapping="Wrap" Width="130" TextAlignment="Center" FontFamily="Comic Sans MS" FontSize="16">
                                    <Run Text="Дата доставки "/>
                                    <Run Text="{Binding Zakaz_.DataDostavki}"/>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Border Background="#ABCFCE" Grid.Row="2">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button FontSize="14" FontFamily="Comic Sans MS" Background="#546F94" Height="40" Margin="10 0" Click="AddZakazPageButton" FontWeight="Bold">
                    Добавить товар
                </Button>
                <Button FontSize="14" FontFamily="Comic Sans MS" Background="#546F94" Height="40" Margin="0 0 10 0" Click="DeletZakazButton" FontWeight="Bold">
                    Удалить товар
                </Button>
                <Button FontSize="14" FontFamily="Comic Sans MS" Background="#546F94" Height="40" Margin="0 0 10 0" Click="RedZakazButton" FontWeight="Bold">
                    Редактировать товар
                </Button>
                <Button FontSize="14" FontFamily="Comic Sans MS" Background="#546F94" Height="40" Margin="0 0 10 0" Click="BackButton" FontWeight="Bold">
                    Назад
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>
