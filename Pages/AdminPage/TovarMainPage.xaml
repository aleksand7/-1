<Page x:Class="WPFChitaiGorod.Pages.AdminPage.TovarMainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WPFChitaiGorod.Pages.AdminPage"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="TovarMainPage"
      Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="7*"/>
            <RowDefinition Height="31*"/>
            <RowDefinition Height="7*"/>
        </Grid.RowDefinitions>

        <Border Background="#ABCFCE" Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <Image Source="/Resources/icon.ico" HorizontalAlignment="Left"/>
                <TextBlock VerticalAlignment="Center" FontFamily="Comic Sans MS" FontSize="30" FontWeight="Bold" Margin="150 0 0 0" HorizontalAlignment="Center">
                    ООО «ЧитайГород»
                </TextBlock>
            </StackPanel>
        </Border>

        <ListView x:Name="TovarTableItems" Grid.Row="1" Margin="10,10,10,10" MaxWidth="1900">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="3" Padding="10" Margin="5" HorizontalAlignment="Stretch">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="5*"/>
                                <ColumnDefinition Width="3*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" BorderBrush="Black" BorderThickness="3">
                                <Image Source="{Binding PhotoPath}" Width="180" Height="180" Stretch="Uniform"/>
                            </Border>
                            <Border Grid.Column="1" BorderBrush="Black" BorderThickness="1" Margin="5" Padding="10">
                                <StackPanel Margin="10 0 0 0" MaxWidth="1000">
                                    <TextBlock TextWrapping="Wrap" FontFamily="Comic Sans MS" FontSize="16" FontWeight="Bold">
                                        <Run Text="{Binding KategoriyTovata_.NameKategoriy}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding NameTovar}"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" FontFamily="Comic Sans MS" FontSize="16">
                                        <Run Text="Описание товара: "/>
                                        <Run Text="{Binding DescriptionTovar}"/>
                                    </TextBlock>
                                    <TextBlock FontFamily="Comic Sans MS" FontSize="16">
                                        <Run Text="Производитель: "/>
                                        <Run Text="{Binding Proizvoditel}"/>
                                    </TextBlock>
                                    <TextBlock FontFamily="Comic Sans MS" FontSize="16">
                                        <Run Text="Поставщик: "/>
                                        <Run Text="{Binding Postavshik}"/>
                                    </TextBlock>
                                    <TextBlock FontFamily="Comic Sans MS" FontSize="16">
                                        <Run Text="Цена: "/>
                                        <Run Text="{Binding Cena}"/>
                                    </TextBlock>
                                    <TextBlock FontFamily="Comic Sans MS" FontSize="16">
                                        <Run Text="Единица измерения: "/>
                                        <Run Text="{Binding EdIzmereniy}"/>
                                    </TextBlock>
                                    <TextBlock FontFamily="Comic Sans MS" FontSize="16">
                                        <Run Text="Количество на складе: "/>
                                        <Run Text="{Binding FolVoNaSclade}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" BorderBrush="Black" BorderThickness="2">
                                <Grid Width="150" Height="150">
                                    <TextBlock TextWrapping="Wrap" Width="130" TextAlignment="Center" FontFamily="Comic Sans MS" FontSize="16">
                                        <Run Text="Действующая скидка "/>
                                        <Run Text="{Binding DeistvSkidka}"/>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Border Background="#ABCFCE" Grid.Row="2">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button FontSize="14" FontFamily="Comic Sans MS" Background="#546F94" Height="40" Margin="10 0" Click="AddTovarPageButton" FontWeight="Bold">
                    Добавить товар
                </Button>
                <Button FontSize="14" FontFamily="Comic Sans MS" Background="#546F94" Height="40" Margin="0 0 10 0" Click="DeletTovarButton" FontWeight="Bold">
                    Удалить товар
                </Button>
                <Button FontSize="14" FontFamily="Comic Sans MS" Background="#546F94" Height="40" Margin="0 0 10 0" Click="RedTovarButton" FontWeight="Bold">
                    Редактировать товар
                </Button>
                <Button FontSize="14" FontFamily="Comic Sans MS" Background="#546F94" Height="40" Margin="0 0 10 0" Click="BackButton" FontWeight="Bold">
                    Назад
                </Button>
                <Button FontSize="14" FontFamily="Comic Sans MS" Background="#546F94" Height="40" Margin="0 0 10 0" Click="SortUbivButton" FontWeight="Bold">
                    Сорт по возрастанию
                </Button>
                <Button FontSize="14" FontFamily="Comic Sans MS" Background="#546F94" Height="40" Margin="0 0 10 0" Click="SortVozrastButton" FontWeight="Bold">
                    Сортпо убыванию
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>
