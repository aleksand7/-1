<Page x:Class="WPFChitaiGorod.Pages.AdminPage.AddTovarPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WPFChitaiGorod.Pages.AdminPage"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddTovarPage"
      Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="309*"/>
            <RowDefinition Height="70*"/>
            <RowDefinition Height="71*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock FontFamily="Comic Sans MS" FontSize="16" Margin="0 0 0 10" HorizontalAlignment="Center">
                Артикул
            </TextBlock>
            <TextBox x:Name="ArtTxt" Width="200" FontFamily="Comic Sans MS">
                
            </TextBox>
            <TextBlock FontFamily="Comic Sans MS" FontSize="16" Margin="0 0 0 10" HorizontalAlignment="Center">
                Название товара
            </TextBlock>
            <TextBox x:Name="NameTxt" Width="200" FontFamily="Comic Sans MS">
                
            </TextBox>
            <TextBlock FontFamily="Comic Sans MS" FontSize="16" Margin="0 0 0 10" HorizontalAlignment="Center">
                Единицы измерения
            </TextBlock>
            <TextBox x:Name="EdTxt" Width="200" FontFamily="Comic Sans MS">
                
            </TextBox>
            <TextBlock FontFamily="Comic Sans MS" FontSize="16" Margin="0 0 0 10" HorizontalAlignment="Center">
                Цена
            </TextBlock>
            <TextBox x:Name="CenaTxt" Width="200" FontFamily="Comic Sans MS">
                
            </TextBox>
            <TextBlock FontFamily="Comic Sans MS" FontSize="16" Margin="0 0 0 10" HorizontalAlignment="Center">
                Поставщик
            </TextBlock>
            <TextBox x:Name="PostavshicTxt" Width="200" FontFamily="Comic Sans MS">
                
            </TextBox>
        </StackPanel>

        <StackPanel Grid.Column="1" Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock FontFamily="Comic Sans MS" FontSize="16" Margin="0 0 0 10" HorizontalAlignment="Center">
                Производитель
            </TextBlock>
            <TextBox x:Name="ProizvodTxt" Width="200" FontFamily="Comic Sans MS">

            </TextBox>
            <TextBlock FontFamily="Comic Sans MS" FontSize="16" Margin="0 0 0 10" HorizontalAlignment="Center">
                Категория товара
            </TextBlock>
            <ComboBox x:Name="KatCombo" Width="200" FontFamily="Comic Sans MS">

            </ComboBox>
            <TextBlock FontFamily="Comic Sans MS" FontSize="16" Margin="0 0 0 10" HorizontalAlignment="Center">
                Скидка
            </TextBlock>
            <TextBox x:Name="SkidkaTxt" Width="200" FontFamily="Comic Sans MS">

            </TextBox>
            <TextBlock FontFamily="Comic Sans MS" FontSize="16" Margin="0 0 0 10" HorizontalAlignment="Center">
                Количество на складе
            </TextBlock>
            <TextBox x:Name="KolVoTxt" Width="200" FontFamily="Comic Sans MS">

            </TextBox>
            <TextBlock FontFamily="Comic Sans MS" FontSize="16" Margin="0 0 0 10" HorizontalAlignment="Center">
                Фото
            </TextBlock>
            <TextBox x:Name="PhotoTxt" Width="200" FontFamily="Comic Sans MS">

            </TextBox>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2">
            <TextBlock FontFamily="Comic Sans MS" FontSize="16" Margin="0 0 0 10" HorizontalAlignment="Center">
                Описание товара
            </TextBlock>
            <TextBox x:Name="DescTxt" Width="500" Height="35" FontFamily="Comic Sans MS" TextWrapping="Wrap">

            </TextBox>
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button FontSize="14" FontFamily="Comic Sans MS" Background="#546F94" Height="40" Margin="10 0" Click="AddTovarButton" FontWeight="Bold">
                Добавить товар
            </Button>
            <Button FontSize="14" FontFamily="Comic Sans MS" Background="#546F94" Height="40" Margin="0 0 10 0" Click="BackPageButton" FontWeight="Bold">
                Назад
            </Button>
        </StackPanel>
    </Grid>
</Page>
