<Page x:Class="Suhankin.Dobavlenie"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Suhankin"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Dobavlenie">

    <Grid Background="Black" >
        <Grid.RowDefinitions>
            <RowDefinition Height="272*"/>
            <RowDefinition Height="119*"/>
            <RowDefinition Height="59*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Grid.Row="0">
            <TextBlock Foreground="White" HorizontalAlignment="Center" Margin="0 5 0 5">
        Артикул
            </TextBlock>
            <TextBox x:Name="ArtTovarTxt" Width="200">

            </TextBox>

            <TextBlock Foreground="White" HorizontalAlignment="Center" Margin="0 5 0 5">
        Название товара
            </TextBlock>
            <TextBox x:Name="NameTovarTxt" Width="200">

            </TextBox>

            <TextBlock Foreground="White" HorizontalAlignment="Center" Margin="0 5 0 5">
        Единицы измерения
            </TextBlock>
            <TextBox x:Name="EdIzmTovarTxt" Width="200">

            </TextBox>

            <TextBlock Foreground="White" HorizontalAlignment="Center" Margin="0 5 0 5">
        Цена
            </TextBlock>
            <TextBox x:Name="PriceTovarTxt" Width="200">

            </TextBox>

            <TextBlock Foreground="White" HorizontalAlignment="Center" Margin="0 5 0 5">
        Поставщик
            </TextBlock>
            <TextBox x:Name="PostavcikTovarTxt" Width="200">

            </TextBox>
        </StackPanel>

        <StackPanel Grid.Column="1" Grid.Row="0">
            <TextBlock Foreground="White" HorizontalAlignment="Center" Margin="0 5 0 5">
        Производитель
            </TextBlock>
            <TextBox x:Name="ProizvoditelTovarTxt" Width="200">

            </TextBox>

            <TextBlock Foreground="White" HorizontalAlignment="Center" Margin="0 5 0 5">
        Категория товара
            </TextBlock>
            <TextBox Width="200" x:Name="KategoryCombo">

            </TextBox>

            <TextBlock Foreground="White" HorizontalAlignment="Center" Margin="0 5 0 5">
        Действующая скидка
            </TextBlock>
            <TextBox x:Name="SkidkaTovarTxt" Width="200">

            </TextBox>

            <TextBlock Foreground="White" HorizontalAlignment="Center" Margin="0 5 0 5">
        Количество на складе
            </TextBlock>
            <TextBox x:Name="KolVoTovarTxt" Width="200">

            </TextBox>

            <TextBlock Foreground="White" HorizontalAlignment="Center" Margin="0 5 0 5">
        Фото товара
            </TextBlock>
            <TextBox x:Name="FotoTovarTxt" Width="200">

            </TextBox>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" >
            <TextBlock Foreground="White" HorizontalAlignment="Center" Margin="0 5 0 5">
        Описание товара
            </TextBlock>
            <TextBox x:Name="DescTovarTxt" Width="500" Height="60">

            </TextBox>
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Height="30" FontSize="18" FontFamily="Times New Roman" Margin="0 0 20 0" Width="100" Click="SaveTovarButton">
                Сохранить
            </Button>

            <Button Height="30" FontSize="18" FontFamily="Times New Roman" Width="100" Click="BackButton">
                Назад
            </Button>
        </StackPanel>
    </Grid>
</Page>
