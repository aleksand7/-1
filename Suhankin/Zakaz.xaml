<Page x:Class="Suhankin.Zakaz"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Suhankin"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Zakaz">

        <Grid Background="#FFFFFF">
            <Grid.RowDefinitions>
                <RowDefinition Height="38*"/>
                <RowDefinition Height="187*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Margin="0,0,0,10">
                <Button Background="#4B0082" Click="Button_Nazad" Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Width="80" Height="40" Margin="10,21,710,10">
                    Назад
                </Button>
            </Border>
        <ListView x:Name="TovarItems" Margin="10" Grid.Row="1">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black"
            BorderThickness="3"
            Padding="10"
            Margin="5"
            HorizontalAlignment="Stretch">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5*"/>
                                <ColumnDefinition Width="3*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                    BorderBrush="Black"
                    BorderThickness="1"
                    Padding="10"
                    Margin="5">
                                <StackPanel Margin="10 0 0 0">
                                    <TextBlock FontSize="16" FontWeight="Bold">
                                <Run Text="Артикул заказа: "/>
                                <Run Text="{Binding Articul}"/>
                                    </TextBlock>

                                    <TextBlock FontSize="16" FontWeight="Bold">
                                <Run Text="Статус заказа: "/>
                                <Run Text="{Binding ZakazImport_.StatusZakaza_.StatusName}"/>
                                    </TextBlock>

                                    <TextBlock FontSize="16" FontWeight="Bold">
                                <Run Text="Адрес пункта выдачи: "/>
                                <Run Text="{Binding ZakazImport_.PunkVidachiImport_.IndexAdres}"/>
                                    </TextBlock>

                                    <TextBlock FontSize="16" FontWeight="Bold">
                                <Run Text="Дата заказа: "/>
                                <Run Text="{Binding ZakazImport_.DataZakaz}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                    BorderBrush="Black"
                    BorderThickness="3">
                                <Grid Width="150" 
                      Height="150">
                                    <TextBlock FontSize="16" 
                               FontWeight="Bold" 
                               TextWrapping="Wrap" 
                               Width="130"
                               TextAlignment="Center">
                                <Run Text="Дата доставки: "/>
                                <Run Text="{Binding ZakazImport_.DataDostavki}"/>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</Page>
