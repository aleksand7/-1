<Page x:Class="Suhankin.Page1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Suhankin"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Page1">

    <Grid Background="White">
        <Border Width="500" Height="300">
            <Grid>
                <TextBlock TextWrapping="Wrap" Text="Авторизуйтесь" FontFamily="Times New Roman" FontSize="25" HorizontalAlignment="Center" Margin="0,0,0,260"></TextBlock>
                <TextBlock TextWrapping="Wrap" Text="Логин" FontFamily="Times New Roman" FontSize="20"  Margin="50,90,380,180"></TextBlock>
                <TextBlock TextWrapping="Wrap" Text="Пароль" FontFamily="Times New Roman" FontSize="20" Margin="50,135,380,130"></TextBlock>
                <TextBox x:Name="txtLogin" TextWrapping="Wrap" Width="250" Height="30" Margin="0,0,0,90" FontSize="20" ></TextBox>
                <TextBox x:Name="psbPass" TextWrapping="NoWrap" Width="250" Height="30" Margin="0,0,0,0" FontSize="20"></TextBox>
                <Button Content="Войти" FontSize="20" FontFamily="Times New Roman" Background="#4B0082" Height="40" Width="120" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,190,0,0" Click="Button_Click"></Button>
                <Button Content="Войти как гость" FontFamily="Times New Roman" FontSize="20" Background="#4B0082" Height="40" Width="150" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,240,0,0" Click="Button_Click_1"></Button>
                <Button Content="Закрыть" FontFamily="Times New Roman" FontSize="20" Background="#4B0082" Height="40" Width="120" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,250,0,0" Click="Button_Click_2"></Button>

            </Grid>
           
        </Border>
         
    </Grid>
</Page>
