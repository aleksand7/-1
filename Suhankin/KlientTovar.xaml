<Page x:Class="Suhankin.KlientTovar"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Suhankin"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="KlientTovar">

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="38*"/>
            <RowDefinition Height="187*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Margin="0,0,0,10">
            <Button Background="#4B0082" Click="Button_Nazad" Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Width="80" Height="40" Margin="10,21,710,10">
                Назад
            </Button>
        </Border>

        <ListView x:Name="Tovar" Margin="10" Grid.Row="1">
            <ListView.ItemTemplate>
                <!-- Толщина границы 1 пиксель -->
                <!-- Внутренний отступ 10 -->
                <!-- Внешний отступ 5 -->
                <DataTemplate>
                    <Border BorderBrush="Black" 
                    BorderThickness="3" 
                    Padding="10"
                    Margin="5">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="10*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Фото товара -->
                            <Border Grid.Column="0" 
                            BorderBrush="Black" 
                            BorderThickness="3" 
                            
                            Width="200" Height="200">
                                <Image Source="{Binding Photo}"
                               Width="180" Height="180"
                               Stretch="Uniform"/>
                                <!-- Stretch="UniformToFill" маштабируемость картинки -->
                            </Border>

                            <!-- Для рамки -->
                            <Border Grid.Column="1"  BorderBrush="Black"  
                                    BorderThickness="1" 
                                    Padding="0"
                                    Margin="5">


                                <!-- Информация о товаре -->
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock FontSize="16" FontWeight="Bold" Width="500" >
                                    <Run Text="{Binding KategoriaTovara}"/>
                                    <Run Text=" / "/>
                                    <Run Text="{Binding NameTovara}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="16" TextWrapping="Wrap" Width="500">
                                   <Run Text=" Описание товара: "/>
                                  <Run Text="{Binding Opi}" />

                                    </TextBlock>
                                    <TextBlock FontSize="16" >
                                    <Run Text=" Производитель: "/>
                                   <Run Text="{Binding Proizvoditel}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="16" >
                                    <Run Text=" Поставщик: "/>
                                    <Run Text="{Binding Postavshik}" />
                                    </TextBlock>
                                    <TextBlock FontSize="16" >
                                   <Run Text=" Цена: "/>
                                    <Run Text="{Binding Stoimost}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="16" >
                                   <Run Text=" Единица измерения: "/>
                                   <Run Text="{Binding Ed_Izmeren}" />
                                    </TextBlock>
                                    <TextBlock FontSize="16" >
                                    <Run Text=" Количество на складе: "/>
                                    <Run Text="{Binding Kol_vo_na_sclade}" />
                                    </TextBlock>
                                </StackPanel>

                            </Border>

                            <Border Grid.Column="2" BorderBrush="Black" BorderThickness="3">
                                <Grid Width="150" Height="150">
                                    <TextBlock FontSize="16" TextWrapping="Wrap" Width="110"
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" TextAlignment="Center">    
                                        <Run Text="Действующая скидка: "/>
                                        <Run Text="{Binding DeistvSkidka}"/>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
